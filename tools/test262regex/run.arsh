#!/usr/bin/env arsh

[<CLI(verbose:$true)>]
type _Test() {
    [<Option(required:$true, help:"executable path of re262")>]
    var bin = ""

    [<Option(required:$true, help:"root dir of test262")>]
    var path = ""

    [<Arg(required:$true, help:"output dir of test results")>]
    var output = ""

    [<Option(help:"number of jobs (default is 4)")>]
    var job = 4
}

let _SKIP_PATTERNS = [
    new Regex(".*${'/prototype/'.escapeRegex()}.*"),
    new Regex(".*${'/legacy-accessors/'.escapeRegex()}.*"),
    new Regex(".*${'/Symbol.species/'.escapeRegex()}.*"),
]
function matchSkipPatterns(path: String): Bool {
    for p in $_SKIP_PATTERNS {
        $p =~ $path && return $true
    }
    return $false
}

function run() for _Test {
    shctl set errraise
    test -e ${this.output} && { echo 1>&2 ${this.output} is already exist; exit 1; }
    mkdir -p ${this.output}
    let testCases = @(${this.path}/test/{,annexB}/built-ins/RegExp/**/*.js).shuffle(42)
    let size = $testCases.size()
    let chunkSize = $size / $this.job
    for(var i = 0; $i < $size; $i += $chunkSize) {
        var chunk = $testCases.slice($i, $i+$chunkSize).sort()
        for f in $chunk {
            $f = $f.realpath()
            printf -v var "%s/%04X.txt" ${this.output} $RANDOM
            var ret = $reply['var']
            assert !(test -e $ret) : "$ret is already exist"
            if $matchSkipPatterns($f) {
                echo "skip: $f > $ret"
                printf -- "%s\n---\n" $f >| $ret
                printf -- "---\n%d\n" 125 >> $ret
            } else {
                echo "run: $f > $ret"
                printf -- "%s\n---\n" $f >| $ret
                call ${this.bin} $f 2>> $ret || $true
                printf -- "---\n%d\n" $? >> $ret
            }
        } &
    }
    wait
}

[<CLI(verbose:$true)>]
type _Report() {
    [<Option(required:$true, help:"root dir of test results")>]
    var path = ""

    [<Arg(required:$true, help:"test report path")>]
    var output = ""
}

type Path {
    let kind: Int
    let value: String
}
function fromDir(path: String): Path {
    return new Path(0, $path)
}
function fromFile(path: String): Path {
    return new Path(1, $path)
}

type Entry() {
    var pass = 0
    var fail = 0
    var skip = 0
    var content = ""
    var error = ""
    let children: [Path: Entry]
}

function load(path: String): (String, Entry) {
    var lines : [String]
    for line in <(< $path) {
        $lines.add($line)
    }
    var casePath = $lines.shift()
    $lines.shift() == "---" || throw new Error('broken format');
    var error : [String]
    while($lines[0] != '---') {
        $error.add($lines.shift())
    }
    assert $lines.size() == 2
    assert $lines[0] == '---'
    var status = $lines[1].toInt()!
    let entry = new Entry()
    $entry.error = $error.join($'\n')
    $entry.content = $casePath
    case $status {
        0 => { $entry.pass++; }
        125 => { $entry.skip++; }
        else => { $entry.fail++; }
    }
    return ($casePath, $entry)
}

function append(root: [Path: Entry], segments: [String], entry: Entry) {
    if $segments.size() == 1 {
        var key = $fromFile($segments[0])
        var r = $root.put($key, $entry)
        assert !$r
        return
    }

    assert $segments.size() > 1
    var dir = $fromDir($segments.shift())
    var e = $root.get($dir) ?? {
        var e = new Entry()
        $root[$dir] = $e
        $e
    }
    $append($e.children, $segments, $entry)
}

function update(entry : Entry) {
    for _, child in $entry.children {
        $update($child)
        $entry.pass += $child.pass
        $entry.fail += $child.fail
        $entry.skip += $child.skip
    }
}

function print(root: [Path: Entry], level: Int) {
    var p = ""
    for(var i = 0; $i < $level; $i++) {
        $p += "#"
    }

    var keys: [Path]
    for k, _  in $root {
        $keys.add($k)
    }
    $keys.sort()

    for k in $keys {
        var v = $root[$k]
        if $v.content.empty() {
            printf "%s %s (pass:%d, fail:%d, skip:%d)\n" $p ${k.value} ${v.pass} ${v.fail} ${v.skip}
        } else {
            printf "%s [%s](%s) (pass:%d, fail:%d, skip:%d)\n" $p ${$v.content.basename()} ${v.content} ${v.pass} ${v.fail} ${v.skip}
        }
        if !$v.error.empty() {
            cat << EOF
\`\`\`
${v.error}
\`\`\`
EOF
        }
        echo
        $print($v.children, $level + 1)
    }
}

function run() for _Report {
    shctl set errraise
    let entries : [(String, Entry)]
    for path in @(${this.path}/*.txt) {
        var tmp = $load($path)
        var casePath = $tmp._0
        var index = $casePath.lastIndexOf("/test262/")
        assert $index != -1
        $casePath = $casePath.slice($index + "/test262/".size())
        $entries.add(($casePath, $tmp._1))
    }
    $entries.sortBy(function(x, y)=> $x._0.compare($y._0))

    var root: [Path: Entry]
    for entry in $entries {
        $append($root, $entry._0.split('/'), $entry._1)
    }
    for _, e in $root {
        $update($e)
    }

    $print($root, 1) with > ${this.output}
}

[<CLI(toplevel:$true)>]
type _Param() {
    [<SubCmd(help:"run test cases")>]
    var test: _Test?

    [<SubCmd(help:"report test results")>]
    var report: _Report?
}

_main(param: _Param) {
    if let test = $param.test {
        $test.run()
    } elif let report = $param.report {
        $report.run()
    } else {
        echo 1>&2 ${$param.usage('require subcommand')}
        return 1
    }
}

shctl is-sourced || _main $@