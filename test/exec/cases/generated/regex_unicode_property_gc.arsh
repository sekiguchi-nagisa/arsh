		$'\UA93F6',  # 򩏶
		$'\UAE543',  # 򮕃
		$'\U104702',  # 􄜂
	],
)
$assertRegex(
	$pattern: $/^[\p{Z}]$/u,
	$matches: [
		$'\U2004',  #  
		$'\U2006',  #  
		$'\U2008',  #  
		$'\U2009',  #  
		$'\U3000',  # 　
