		$'\UA93F6',  # 򩏶
		$'\UAE543',  # 򮕃
		$'\U104702',  # 􄜂
	],
)
$assertRegex(
	$pattern: $/^[\p{Symbol}]$/u,
	$matches: [
		$'\U3265',  # ㉥
		$'\U1CD9E',  # 𜶞
		$'\U1D22A',  # 𝈪
		$'\U1D828',  # 𝠨
