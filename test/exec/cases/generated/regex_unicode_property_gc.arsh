		$'\UA872D',  # 򨜭
		$'\UAD91B',  # 򭤛
		$'\U104591',  # 􄖑
	],
)
$assertRegex(
	$pattern: $/^[\p{Separator}]$/u,
	$matches: [
		$'\U2004',  #  
		$'\U2006',  #  
		$'\U2008',  #  
		$'\U2009',  #  
		$'\U3000',  # 　
	],
	$noMatches: [
		$'\U6651D',  # 񦔝
		$'\U8B833',  # 򋠳
		$'\UA872D',  # 򨜭
		$'\UAD91B',  # 򭤛
		$'\U104591',  # 􄖑
	],
)
$assertRegex(
	$pattern: $/^[\p{C}]$/u,
	$matches: [
		$'\U7E921',  # 񾤡
		$'\U9E6F5',  # 򞛵
		$'\UB739B',  # 򷎛
		$'\UBB9CC',  # 򻧌
		$'\U106047',  # 􆁇
	],
	$noMatches: [
		$'\U11A1C',  # 𑨜
		$'\U1F041',  # 🁁
		$'\U23848',  # 𣡈
		$'\U24406',  # 𤐆
		$'\U31AB3',  # 𱪳
	],
)
$assertRegex(
	$pattern: $/^[\p{Other}]$/u,
	$matches: [
		$'\U7E921',  # 񾤡
		$'\U9E6F5',  # 򞛵
		$'\UB739B',  # 򷎛
		$'\UBB9CC',  # 򻧌
		$'\U106047',  # 􆁇
	],
	$noMatches: [
		$'\U11A1C',  # 𑨜
