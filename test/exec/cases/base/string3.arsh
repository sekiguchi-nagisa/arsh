
# for escape
## glob
assert "**/*.txt".escapeGlob() == '\*\*/\*.txt'
assert "t?".escapeGlob() == 't\?'
assert '[a-v]*'.escapeGlob() == '\[a\-v\]\*'
assert '[^a-v][!a]?'.escapeGlob() == '\[\^a\-v\]\[\!a\]\?'
assert '!'.escapeGlob() == '\!'

## regex
assert '^.*?$'.escapeRegex() == '\^\.\*\?\$'
assert 'hello!!'.escapeRegex() == '\x68ello\x21\x21'
assert '[^A-z]*'.escapeRegex() == '\[\^A\x2dz\]\*'
assert '!'.escapeRegex() == '\x21'

## too large result
var large = "!"
for(var i = 0; $i < 30; $i++) {
    $large += $large
}

var ex = 23 as Any
try { assert $large.escapeGlob() == ''; } catch e { $ex = $e; }
assert ($ex as OutOfRangeError).message() == "reach String size limit"

$ex = 2345
try { assert $large.escapeRegex() == ''; } catch e { $ex = $e; }
assert ($ex as OutOfRangeError).message() == "reach String size limit"