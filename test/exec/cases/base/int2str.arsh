
let values  = [-1, -2, 0, 1, 2, 9223372036854775807, -9223372036854775807 - 1, -2147483648, 2147483647, 4294967295]
for(var i = 0; $i < 300; $i++) {
    let v = try { $RANDOM * ($RANDOM%2 == 0 ? 1 : -1) } catch e: ArithmeticError { continue; }
    $values.push($v)
}

assert ! "".toInt()
assert  "12".toInt(0)! == 12
assert ! "12".toInt(1)
assert "11".toInt(36)! == 37
assert ! "11".toInt(37)
assert !'ffffffffffffffff'.toInt(16)
assert !'ffffffffffffffff'.toInt(16, $false)
assert 'ffffffffffffffff'.toInt(16, $true)! == -1

assert ! 10.toString(0)
assert ! 10.toString(1)
assert ! 10.toString(37)
assert  10.toString(36)! == 'a'
assert (-1).toString(16)! == '-1'
assert (-1).toString(16, $false)! == '-1'
assert (-1).toString(16, $true)! == 'ffffffffffffffff'

for(var i = 2; $i <= 36; $i++) {
    for v in $values {
        assert $v == $v.toString($i, $true)!.toInt($i, $true)!
        assert $v == $v.toString($i, $false)!.toInt($i, $false)!
    }
}