
source $SCRIPT_DIR/../syntax/test_helper.arsh

# (あ)
assert diff <(redump -d '(あ)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
   0: BeginCapture(captureIndex=1)
   3: Char(codePoint=U+3042:あ)
   8: EndCapture(captureIndex=1)
  11: Match
matchers:
EOF
)

assert diff <(redump -d '(あ)' 'i') <(<<'EOF'
flag: (mode = , modifier = i)
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
   0: BeginCapture(captureIndex=1)
   3: IChar(codePoint=U+3042:あ)
   8: EndCapture(captureIndex=1)
  11: Match
matchers:
EOF
)

# (あ[\w])い
assert diff <(redump -d '(あ[\w])い' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
   0: BeginCapture(captureIndex=1)
   3: Char(codePoint=U+3042:あ)
   8: CharSet(matcherIndex=0, invert=false)
  12: EndCapture(captureIndex=1)
  15: Char(codePoint=U+3044:い)
  20: Match
matchers:
  0: AsciiSet
{ 0x0030, 0x0039 },
{ 0x0041, 0x005A },
{ 0x005F, 0x005F },
{ 0x0061, 0x007A },
EOF
)

assert diff <(redump -d '(あ[\w])い' 'i') <(<<'EOF'
flag: (mode = , modifier = i)
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
   0: BeginCapture(captureIndex=1)
   3: IChar(codePoint=U+3042:あ)
   8: ICharSet(matcherIndex=0, invert=false)
  12: EndCapture(captureIndex=1)
  15: IChar(codePoint=U+3044:い)
  20: Match
matchers:
  0: AsciiSet
{ 0x0030, 0x0039 },
{ 0x005F, 0x005F },
{ 0x0061, 0x007A },
EOF
)

# (a.)|(c.)
assert diff <(redump -d '(a.)|(c.)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 2
namedCaptureGroups: []
instructions:
   0: Alt(second=22)
   5: BeginCapture(captureIndex=1)
   8: Char(codePoint=U+0061:a)
  13: AnyExceptNL
  14: EndCapture(captureIndex=1)
  17: Jump(target=34)
  22: BeginCapture(captureIndex=2)
  25: Char(codePoint=U+0063:c)
  30: AnyExceptNL
  31: EndCapture(captureIndex=2)
  34: Match
matchers:
EOF
)

# (?<=(a.)|(c.))
assert diff <(redump -d '(?<=(a.)|(c.))' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 2
namedCaptureGroups: []
instructions:
   0: BeginLookAround(negate=false, target=44)
   6: Alt(second=30)
  11: BeginCapture(captureIndex=1)
  14: LBAny(dotAll=false)
  16: LBChar(ignoreCase=false, codePoint=U+0061:a)
  22: LBEndCapture(captureIndex=1)
  25: Jump(target=44)
  30: BeginCapture(captureIndex=2)
  33: LBAny(dotAll=false)
  35: LBChar(ignoreCase=false, codePoint=U+0063:c)
  41: LBEndCapture(captureIndex=2)
  44: EndLookAround
  45: Match
matchers:
EOF
)

assert diff <(redump -d '(?<=(a.)|(c.))' 'i') <(<<'EOF'
flag: (mode = , modifier = i)
loopCount: 0
captureGroupCount: 2
namedCaptureGroups: []
instructions:
   0: BeginLookAround(negate=false, target=44)
   6: Alt(second=30)
  11: BeginCapture(captureIndex=1)
  14: LBAny(dotAll=false)
  16: LBChar(ignoreCase=true, codePoint=U+0061:a)
  22: LBEndCapture(captureIndex=1)
  25: Jump(target=44)
  30: BeginCapture(captureIndex=2)
  33: LBAny(dotAll=false)
  35: LBChar(ignoreCase=true, codePoint=U+0063:c)
  41: LBEndCapture(captureIndex=2)
  44: EndLookAround
  45: Match
matchers:
EOF
)

# (a.|(?s:b.))c
assert diff <(redump -d '(a.|(?s:b.))c' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
   0: BeginCapture(captureIndex=1)
   3: Alt(second=19)
   8: Char(codePoint=U+0061:a)
  13: AnyExceptNL
  14: Jump(target=25)
  19: Char(codePoint=U+0062:b)
  24: Any
  25: EndCapture(captureIndex=1)
  28: Char(codePoint=U+0063:c)
  33: Match
matchers:
EOF
)

# (?<first>(?<second>a)|(?<second>b))c
assert diff <(redump -d '(?<first>(?<second>a)|(?<second>b))c' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 3
namedCaptureGroups: [first: 1, second: [2, 3]]
instructions:
   0: BeginCapture(captureIndex=1)
   3: Alt(second=24)
   8: BeginCapture(captureIndex=2)
  11: Char(codePoint=U+0061:a)
  16: EndCapture(captureIndex=2)
  19: Jump(target=35)
  24: BeginCapture(captureIndex=3)
  27: Char(codePoint=U+0062:b)
  32: EndCapture(captureIndex=3)
  35: EndCapture(captureIndex=1)
  38: Char(codePoint=U+0063:c)
  43: Match
matchers:
EOF
)