
source $SCRIPT_DIR/../syntax/test_helper.arsh

# \p{RGI_Emoji_ZWJ_Sequence}
assert diff <(redump -d '\p{RGI_Emoji_ZWJ_Sequence}' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: Emoji(emoji=RGI_Emoji_ZWJ_Sequence)
  2: Match
matchers:
EOF
)

assert diff <(redump -d '\p{RGI_Emoji_ZWJ_Sequence}' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: IEmoji(emoji=RGI_Emoji_ZWJ_Sequence|case-ignore)
  2: Match
matchers:
EOF
)

