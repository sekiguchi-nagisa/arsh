# (?<=\p{RGI_Emoji_ZWJ_Sequence})
assert diff <(redump -d '(?<=\p{RGI_Emoji_ZWJ_Sequence})' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: BeginLookAround(negate=false, target=8)
  6: LBEmoji(emoji=RGI_Emoji_ZWJ_Sequence)
  8: EndLookAround
  9: Match
matchers:
EOF
)

assert diff <(redump -d '(?<=\p{RGI_Emoji_ZWJ_Sequence})' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: BeginLookAround(negate=false, target=8)
  6: LBEmoji(emoji=RGI_Emoji_ZWJ_Sequence|case-ignore)
  8: EndLookAround
  9: Match
matchers:
EOF
)

