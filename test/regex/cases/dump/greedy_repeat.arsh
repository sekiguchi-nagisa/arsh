
source $SCRIPT_DIR/../syntax/test_helper.arsh

# a*
assert diff <(redump -d 'a*' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 1
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: BeginLoop(loopIndex=0, greedy=true, min=0, max=4294967295, outer=24)
  14: Char(codePoint=U+0061:a)
  19: EndLoop(target=0)
  24: Match
matchers:
EOF
)

# a+
assert diff <(redump -d 'a+' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 1
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: BeginLoop(loopIndex=0, greedy=true, min=1, max=4294967295, outer=24)
  14: Char(codePoint=U+0061:a)
  19: EndLoop(target=0)
  24: Match
matchers:
EOF
)

# a?
assert diff <(redump -d 'a?' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 1
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: BeginLoop(loopIndex=0, greedy=true, min=0, max=1, outer=24)
  14: Char(codePoint=U+0061:a)
