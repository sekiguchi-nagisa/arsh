
source $SCRIPT_DIR/../syntax/test_helper.arsh

# A
assert diff <(redump -d 'A' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: Char(codePoint=U+0041:A)
  5: Match
matchers:
EOF
)

assert diff <(redump -d 'A' 'i') <(<<'EOF'
flag: (mode = , modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: IChar(codePoint=U+0061:a)
  5: Match
matchers:
EOF
)

