# (?<!A)a
assert diff <(redump -d '(?<!A)a' 'u') <(<<'EOF'
flag: (mode = u, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: BeginLookAround(negate=true, target=12)
   6: LBChar(ignoreCase=false, codePoint=U+0041:A)
  12: EndLookAround
  13: Char(codePoint=U+0061:a)
  18: Match
matchers:
EOF
)

assert diff <(redump -d '(?<!A)a' 'iu') <(<<'EOF'
flag: (mode = u, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: BeginLookAround(negate=true, target=12)
   6: LBChar(ignoreCase=true, codePoint=U+0061:a)
  12: EndLookAround
  13: IChar(codePoint=U+0061:a)
  18: Match
matchers:
EOF
)