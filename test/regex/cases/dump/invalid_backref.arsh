matchers:
EOF
)

# (?<=(?<A>\k<A>)|(?<A>A))
assert diff <(redump -d '(?<=(?<A>\k<A>)|(?<A>A))' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
