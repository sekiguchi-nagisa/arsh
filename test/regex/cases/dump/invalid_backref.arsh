   5: BeginCapture(captureIndex=1)
   8: Char(codePoint=U+0042:B)
  13: EndCapture(captureIndex=1)
  16: Jump(target=32)
  21: BeginCapture(captureIndex=2)
  24: Char(codePoint=U+0041:A)
  29: EndCapture(captureIndex=2)
  32: Match
matchers:
EOF
)

# (?<=()\1A)
assert diff <(redump -d '(?<=()\1A)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
   0: BeginLookAround(negate=false, target=19)
   6: LBChar(ignoreCase=false, codePoint=U+0041:A)
  12: BeginCapture(captureIndex=1)
  15: Nop
  16: LBEndCapture(captureIndex=1)
  19: EndLookAround
  20: Match
matchers:
EOF
)

