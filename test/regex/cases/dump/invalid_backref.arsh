  11: BeginCapture(captureIndex=1)
  14: LBEndCapture(captureIndex=1)
  17: Jump(target=34)
  22: BeginCapture(captureIndex=2)
  25: LBChar(ignoreCase=false, codePoint=U+0041:A)
