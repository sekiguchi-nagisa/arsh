
source $SCRIPT_DIR/../syntax/test_helper.arsh

# (\1)
assert diff <(redump -d '(\1)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
  0: BeginCapture(captureIndex=1)
  3: EndCapture(captureIndex=1)
  6: Match
matchers:
EOF
)

# (.\1.)
assert diff <(redump -d '(.\1.)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
  0: BeginCapture(captureIndex=1)
  3: AnyExceptNL
  4: AnyExceptNL
  5: EndCapture(captureIndex=1)
  8: Match
matchers:
EOF
)

# \1()
assert diff <(redump -d '\1()' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
  0: BeginCapture(captureIndex=1)
  3: Nop
  4: EndCapture(captureIndex=1)
  7: Match
matchers:
EOF
)

# \1(\d)
assert diff <(redump -d '\1(\d)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: []
instructions:
   0: BeginCapture(captureIndex=1)
   3: CharSet(matcherIndex=0, invert=false)
   7: EndCapture(captureIndex=1)
  10: Match
matchers:
  0: AsciiSet
{ 0x0030, 0x0039 },
EOF
)

# (?<A>\k<A>)
assert diff <(redump -d '(?<A>\k<A>)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: [A: 1]
instructions:
  0: BeginCapture(captureIndex=1)
  3: EndCapture(captureIndex=1)
  6: Match
matchers:
EOF
)

# (?<A>.\k<A>.)
assert diff <(redump -d '(?<A>.\k<A>.)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: [A: 1]
instructions:
  0: BeginCapture(captureIndex=1)
  3: AnyExceptNL
  4: AnyExceptNL
  5: EndCapture(captureIndex=1)
  8: Match
matchers:
EOF
)

# \k<A>(?<A>.)
assert diff <(redump -d '\k<A>(?<A>.)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 1
namedCaptureGroups: [A: 1]
instructions:
  0: BeginCapture(captureIndex=1)
  3: AnyExceptNL
  4: EndCapture(captureIndex=1)
  7: Match
matchers:
EOF
)

# (?<A>\k<A>)|(?<A>A)
assert diff <(redump -d '(?<A>\k<A>)|(?<A>A)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 2
namedCaptureGroups: [A: [1, 2]]
instructions:
   0: Alt(second=16)
   5: BeginCapture(captureIndex=1)
   8: EndCapture(captureIndex=1)
  11: Jump(target=27)
  16: BeginCapture(captureIndex=2)
  19: Char(codePoint=U+0041:A)
  24: EndCapture(captureIndex=2)
  27: Match
matchers:
EOF
)

# (?<A>B)|(?<A>A\k<A>)
assert diff <(redump -d '(?<A>B)|(?<A>A\k<A>)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 2
namedCaptureGroups: [A: [1, 2]]
instructions:
   0: Alt(second=21)
   5: BeginCapture(captureIndex=1)
   8: Char(codePoint=U+0042:B)
  13: EndCapture(captureIndex=1)
  16: Jump(target=32)
  21: BeginCapture(captureIndex=2)
  24: Char(codePoint=U+0041:A)
  29: EndCapture(captureIndex=2)
  32: Match
matchers:
EOF
)

# \k<A>(?<A>B)|(?<A>A)
assert diff <(redump -d '\k<A>(?<A>B)|(?<A>A)' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 2
namedCaptureGroups: [A: [1, 2]]
instructions:
   0: Alt(second=21)
   5: BeginCapture(captureIndex=1)
   8: Char(codePoint=U+0042:B)
  13: EndCapture(captureIndex=1)
  16: Jump(target=32)
  21: BeginCapture(captureIndex=2)
  24: Char(codePoint=U+0041:A)
  29: EndCapture(captureIndex=2)
  32: Match
matchers:
EOF
)

# (?<A>B)|\k<A>(?<A>A)
assert diff <(redump -d '(?<A>B)|\k<A>(?<A>A)' '') <(<<'EOF' # valid backref
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 2
namedCaptureGroups: [A: [1, 2]]
instructions:
   0: Alt(second=21)
   5: BeginCapture(captureIndex=1)
   8: Char(codePoint=U+0042:B)
  13: EndCapture(captureIndex=1)
  16: Jump(target=36)
  21: BackRef(index=0, named=true)
  25: BeginCapture(captureIndex=2)
  28: Char(codePoint=U+0041:A)
  33: EndCapture(captureIndex=2)
  36: Match
matchers:
EOF
)

# \k<A>(?:(?<A>B)|(?<A>A))
assert diff <(redump -d '\k<A>(?:(?<A>B)|(?<A>A))' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
