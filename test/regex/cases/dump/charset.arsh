
source $SCRIPT_DIR/../syntax/test_helper.arsh

# []
assert diff <(redump -d '[]' '') <(<<'EOF'
flag: (mode = , modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: CharSet(matcherIndex=0, invert=false)
  4: Match
matchers:
  0: AsciiSet
EOF
)

assert diff <(redump -d '[]' 'i') <(<<'EOF'
flag: (mode = , modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: ICharSet(matcherIndex=0, invert=false)
  4: Match
matchers:
  0: AsciiSet
EOF
)

