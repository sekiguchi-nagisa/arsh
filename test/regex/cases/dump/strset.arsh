
source $SCRIPT_DIR/../syntax/test_helper.arsh

# [\q{}]
assert diff <(redump -d '[\q{}]' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: Match
matchers:
EOF
)

assert diff <(redump -d '[\q{}]' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: Match
matchers:
EOF
)

# [\q{|}\q{||}\q{}]
assert diff <(redump -d '[\q{|}\q{||}\q{}]' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
