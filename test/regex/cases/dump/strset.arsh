matchers:
EOF
)

# (?<![\q{|}\q{||}\q{}])
assert diff <(redump -d '(?<![\q{|}\q{||}\q{}])' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: BeginLookAround(negate=true, target=6)
  6: EndLookAround
  7: Match
matchers:
EOF
)

assert diff <(redump -d '(?<![\q{|}\q{||}\q{}])' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: BeginLookAround(negate=true, target=6)
  6: EndLookAround
  7: Match
matchers:
EOF
)

# [\q{A|あ|}]
assert diff <(redump -d '[\q{A|あ|}]' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: CharSet(matcherIndex=0, invert=false)
  4: Match
matchers:
  0: CodePointSet(owned)
{ 0x0041, 0x0041 },
{ 0x3042, 0x3042 },
EOF
)

assert diff <(redump -d '[\q{A|あ|}]' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: ICharSet(matcherIndex=0, invert=false)
  4: Match
matchers:
  0: CodePointSet(owned)
{ 0x0061, 0x0061 },
{ 0x3042, 0x3042 },
EOF
)

# [\q{AB|あ}]
assert diff <(redump -d '[\q{AB|あ}]' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: StrSetOr(emoji=, index=1, nextOffset=4)
  5: CharSet(matcherIndex=0, invert=false)
  9: Match
matchers:
  0: CodePointSet(owned)
{ 0x3042, 0x3042 },
  1: RadixTree
property: 0x01, string: 0x4142
EOF
)

assert diff <(redump -d '[\q{AB|あ}]' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: IStrSetOr(emoji=case-ignore, index=1, nextOffset=4)
  5: ICharSet(matcherIndex=0, invert=false)
  9: Match
matchers:
  0: CodePointSet(owned)
{ 0x3042, 0x3042 },
  1: RadixTree
property: 0x01, string: 0x6162
EOF
)

# [\q{|AB|あ||い|ABC|}]
assert diff <(redump -d '[\q{|AB|あ||い|ABC|}]' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: StrSetOr(emoji=, index=1, nextOffset=4)
  5: CharSet(matcherIndex=0, invert=false)
  9: Match
matchers:
  0: CodePointSet(owned)
{ 0x3042, 0x3042 },
{ 0x3044, 0x3044 },
  1: RadixTree
property: 0x01, string: 0x4142
property: 0x01, string: 0x414243
EOF
)

assert diff <(redump -d '[\q{|AB|あ||い|ABC|}]' 'iv') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: IStrSetOr(emoji=case-ignore, index=1, nextOffset=4)
  5: ICharSet(matcherIndex=0, invert=false)
  9: Match
