# [\q{A|あ|}]
assert diff <(redump -d '[\q{A|あ|}]' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: Alt(second=9)
  5: CharSet(matcherIndex=0, invert=false)
  9: Match
matchers:
  0: CodePointSet(owned)
{ 0x0041, 0x0041 },
{ 0x3042, 0x3042 },
EOF
)

assert diff <(redump -d '[\q{A|あ|}]' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
  0: Alt(second=9)
  5: ICharSet(matcherIndex=0, invert=false)
  9: Match
matchers:
  0: CodePointSet(owned)
{ 0x0061, 0x0061 },
{ 0x3042, 0x3042 },
EOF
)

# [\q{AB|あ}]
assert diff <(redump -d '[\q{AB|あ}]' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: PrepareRadix
   1: RadixOrEmoji(emoji=, hasRadix=true, index=0, nextOffset=4)
   7: CharSet(matcherIndex=1, invert=false)
  11: Match
matchers:
  0: RadixTree
property: 0x01, string: 0x4142
  1: CodePointSet(owned)
{ 0x3042, 0x3042 },
EOF
)

assert diff <(redump -d '[\q{AB|あ}]' 'vi') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: PrepareRadix
   1: RadixOrEmoji(emoji=case-ignore, hasRadix=true, index=0, nextOffset=4)
   7: ICharSet(matcherIndex=1, invert=false)
  11: Match
matchers:
  0: RadixTree
property: 0x01, string: 0x6162
  1: CodePointSet(owned)
{ 0x3042, 0x3042 },
EOF
)

