matchers:
EOF
)

assert diff <(redump -d '[\q{|}\q{||}\q{}]' 'iv') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
