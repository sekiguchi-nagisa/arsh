# [\q{あいう}\q{↔️}\p{Basic_Emoji}\p{Emoji_Keycap_Sequence}[\p{RGI_Emoji_Modifier_Sequence}\q{Ⓜ️|}\p{RGI_Emoji_Modifier_Sequence}\p{RGI_Emoji_Flag_Sequence}]\p{RGI_Emoji_Tag_Sequence}\p{RGI_Emoji_ZWJ_Sequence}\w\q{あいう|あい}]
assert diff <(redump -d
    '[\q{あいう}\q{↔️}\p{Basic_Emoji}\p{Emoji_Keycap_Sequence}[\p{RGI_Emoji_Modifier_Sequence}\q{Ⓜ️|}\p{RGI_Emoji_Modifier_Sequence}\p{RGI_Emoji_Flag_Sequence}]\p{RGI_Emoji_Tag_Sequence}\p{RGI_Emoji_ZWJ_Sequence}\w\q{あいう|あい}]'
     'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: Alt(second=16)
   5: PrepareRadix
   6: RadixOrEmoji(emoji=RGI_Emoji, hasRadix=true, index=0, nextOffset=4)
  12: CharSet(matcherIndex=1, invert=false)
  16: Match
matchers:
  0: RadixTree
property: 0x01, string: 0xE38182E38184
property: 0x01, string: 0xE38182E38184E38186
  1: CodePointSet(owned)
{ 0x0030, 0x0039 },
{ 0x0041, 0x005A },
{ 0x005F, 0x005F },
{ 0x0061, 0x007A },
EOF
)

assert diff <(redump -d
    '[\q{あいう}\q{↔️}\p{Basic_Emoji}\p{Emoji_Keycap_Sequence}[\p{RGI_Emoji_Modifier_Sequence}\q{Ⓜ️|}\p{RGI_Emoji_Modifier_Sequence}\p{RGI_Emoji_Flag_Sequence}]\p{RGI_Emoji_Tag_Sequence}\p{RGI_Emoji_ZWJ_Sequence}\w\q{あいう|あい}]'
