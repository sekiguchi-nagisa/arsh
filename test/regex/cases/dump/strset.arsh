# (?<=[\q{AB}[\q{あ}い]\q{ABC|}\q{}[\w]])
assert diff <(redump -d '(?<=[\q{AB}[\q{あ}い]\q{ABC|}\q{}[\w]])' 'v') <(<<'EOF'
flag: (mode = v, modifier = )
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: BeginLookAround(negate=false, target=23)
   6: Alt(second=23)
  11: PrepareLBRadix
  12: LBRadixOrEmoji(emoji=, hasRadix=true, index=0, nextOffset=5)
  18: LBCharSet(matcherIndex=1, invert=false, ignoreCase=false)
  23: EndLookAround
  24: Match
matchers:
  0: RadixTree
property: 0x01, string: 0x4142
property: 0x01, string: 0x414243
  1: CodePointSet(owned)
{ 0x0030, 0x0039 },
{ 0x0041, 0x005A },
{ 0x005F, 0x005F },
{ 0x0061, 0x007A },
{ 0x3042, 0x3042 },
{ 0x3044, 0x3044 },
EOF
)

assert diff <(redump -d '(?<=[\q{AB}[\q{あ}い]\q{ABC|}\q{}[\w]])' 'iv') <(<<'EOF'
flag: (mode = v, modifier = i)
loopCount: 0
captureGroupCount: 0
namedCaptureGroups: []
instructions:
   0: BeginLookAround(negate=false, target=23)
   6: Alt(second=23)
  11: PrepareLBRadix
  12: LBRadixOrEmoji(emoji=case-ignore, hasRadix=true, index=0, nextOffset=5)
  18: LBCharSet(matcherIndex=1, invert=false, ignoreCase=true)
  23: EndLookAround
  24: Match
matchers:
  0: RadixTree
property: 0x01, string: 0x6162
property: 0x01, string: 0x616263
  1: CodePointSet(owned)
{ 0x0030, 0x0039 },
{ 0x005F, 0x005F },
{ 0x0061, 0x007A },
{ 0x3042, 0x3042 },
{ 0x3044, 0x3044 },
EOF
)

