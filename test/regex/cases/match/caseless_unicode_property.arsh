
source $SCRIPT_DIR/../syntax/test_helper.arsh

# \p{Lu}
assert diff <(redump -m '12@-_3aB)' '\p{Lu}' 'u') <(<<'EOF'
input: `12@-_3aB)'
(offset=7, size=1)
EOF
)

assert diff <(redump -m '12@-_3aB)' '\p{Lu}' 'iu') <(<<'EOF'
input: `12@-_3aB)'
(offset=6, size=1)
EOF
)

# \P{Lu}
assert diff <(redump -m 'A12@-_3aB)' '\P{Lu}' 'u') <(<<'EOF'
input: `A12@-_3aB)'
(offset=1, size=1)
EOF
)

assert diff <(redump -m 'A12@-_3aB)' '\P{Lu}' 'iu') <(<<'EOF'
input: `A12@-_3aB)'
(offset=0, size=1)
EOF
)

# \p{sc=Latin}
assert diff <(redump -m '12@-_3aB)' '\p{sc=Latin}' 'u') <(<<'EOF'
input: `12@-_3aB)'
(offset=6, size=1)
EOF
)

assert diff <(redump -m '12@-_3aB)' '\p{sc=Latin}' 'ui') <(<<'EOF'
input: `12@-_3aB)'
(offset=6, size=1)
EOF
)

# \P{sc=Latin}
assert diff <(redump -m 'wあ12@-_3aB)' '\P{sc=Latin}' 'iu') <(<<'EOF'
input: `wあ12@-_3aB)'
(offset=1, size=3)
EOF
)

# \p{scx=Arab}
assert diff <(redump -m $'@\U0670' '\p{scx=Arab}' 'iu') <(<<EOF
input: \`${$'@\U0670'}'
(offset=1, size=2)
EOF
)

# \P{scx=Arab}
assert diff <(redump -m $'@\U0670' '\P{scx=Arab}' 'iu') <(<<EOF
input: \`${$'@\U0670'}'
(offset=0, size=1)
EOF
)

# \p{Math}
assert diff <(redump -m $'w@+,' '\p{Math}' 'iu') <(<<'EOF'
input: `w@+,'
(offset=2, size=1)
EOF
)

# \P{Math}
assert diff <(redump -m $'-+w@+A' '\P{Math}' 'ui') <(<<'EOF'
input: `-+w@+A'
(offset=0, size=1)
EOF
)