
source $SCRIPT_DIR/../syntax/test_helper.arsh

# (?<=(a)).
assert diff <(redump -m '12ab' '(?<=(a)).' '') <(<<'EOF'
input: `12ab'
(offset=3, size=1)
(offset=2, size=1)
EOF
)

# (?<=(あ))
assert diff <(redump -m '12aあr' '(?<=(あ))' '') <(<<'EOF'
input: `12aあr'
(offset=6, size=0)
(offset=3, size=3)
EOF
)

# (?<=(あい)r)
assert diff <(redump -m '12aあいr' '(?<=(あい)r)' '') <(<<'EOF'
input: `12aあいr'
(offset=10, size=0)
(offset=3, size=6)
EOF
)

# (?<=(ab)|(cd))
assert diff <(redump -m 'ab' '(?<=(ab)|(cd))' '') <(<<'EOF'
input: `ab'
(offset=2, size=0)
(offset=0, size=2)
(unset)
EOF
)

assert diff <(redump -m 'cd' '(?<=(ab)|(cd))' '') <(<<'EOF'
input: `cd'
(offset=2, size=0)
(unset)
(offset=0, size=2)
EOF
)

# (?<=(ab|abd)c)
assert diff <(redump -m '2abc' '(?<=(ab|abd)c)' '') <(<<'EOF'
input: `2abc'
(offset=4, size=0)
(offset=1, size=2)
EOF
)

assert diff <(redump -m '2abdc' '(?<=(ab|abd)c)' '') <(<<'EOF'
input: `2abdc'
(offset=5, size=0)
(offset=1, size=3)
EOF
)

# (?<=((?<first>ab)|(?<second>abd))c)
assert diff <(redump -m '2abc' '(?<=((?<first>ab)|(?<second>abd))c)' '') <(<<'EOF'
input: `2abc'
(offset=4, size=0)
(offset=1, size=2)
(offset=1, size=2)
(unset)
EOF
)

assert diff <(redump -m '2abdc' '(?<=((?<first>ab)|(?<second>abd))c)' '') <(<<'EOF'
input: `2abdc'
(offset=5, size=0)
(offset=1, size=3)
(unset)
(offset=1, size=3)
EOF
)

# (?<=(?:(a)|(ab))(?:(c)|(bc)))
assert diff <(redump -m 'abc' '(?<=(?:(a)|(ab))(?:(c)|(bc)))' '') <(<<'EOF'
input: `abc'
(offset=3, size=0)
(unset)
(offset=0, size=2)
(offset=2, size=1)
(unset)
EOF
)