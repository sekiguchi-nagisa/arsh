
source $SCRIPT_DIR/../syntax/test_helper.arsh

# auto-suggested test cases

# *?
assert diff <(redump -m 'aaab' 'a*?b' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
EOF
)

assert diff <(redump -m 'aaa' 'a*?' '') <(<<'EOF'
input: `aaa'
(offset=0, size=0)
EOF
)

assert diff <(redump -m 'aaabaaab' 'a*?b' '') <(<<'EOF'
input: `aaabaaab'
(offset=0, size=4)
EOF
)

# +?
assert diff <(redump -m 'aaab' 'a+?b' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
EOF
)

assert diff <(redump -m 'bbb' 'a+?' '') <(<<'EOF'
input: `bbb'
failed
EOF
)

assert diff <(redump -m 'aaa' 'a+?' '') <(<<'EOF'
input: `aaa'
(offset=0, size=1)
EOF
)

# ??
assert diff <(redump -m 'ab' 'a??b' '') <(<<'EOF'
input: `ab'
(offset=0, size=2)
EOF
)

assert diff <(redump -m 'aa' 'a??a' '') <(<<'EOF'
input: `aa'
(offset=0, size=1)
EOF
)

assert diff <(redump -m 'color' 'colou??r' '') <(<<'EOF'
input: `color'
(offset=0, size=5)
EOF
)

assert diff <(redump -m 'colour' 'colou??r' '') <(<<'EOF'
input: `colour'
(offset=0, size=6)
EOF
)

# {n,m}?
assert diff <(redump -m 'aaaaab' 'a{2,4}?b' '') <(<<'EOF'
input: `aaaaab'
(offset=1, size=5)
EOF
)

assert diff <(redump -m 'aaaa' 'a{1,3}?' '') <(<<'EOF'
input: `aaaa'
(offset=0, size=1)
EOF
)

assert diff <(redump -m 'a' 'a{2,4}?' '') <(<<'EOF'
input: `a'
failed
EOF
)

assert diff <(redump -m 'aaaab' 'a{3}?b' '') <(<<'EOF'
input: `aaaab'
(offset=1, size=4)
EOF
)

# complicated cases
assert diff <(redump -m '<b>text</b>' '<.*>' '') <(<<'EOF'
input: `<b>text</b>'
(offset=0, size=11)
EOF
)

assert diff <(redump -m '<b>text</b>' '<.*?>' '') <(<<'EOF'
input: `<b>text</b>'
(offset=0, size=3)
EOF
)

assert diff <(redump -m '<a><b><c>' '<.*?>' '') <(<<'EOF'
input: `<a><b><c>'
(offset=0, size=3)
EOF
)

assert diff <(redump -m '"hello" and "word"' '".*?"' '') <(<<'EOF'
input: `"hello" and "word"'
(offset=0, size=7)
EOF
)

assert diff <(redump -m 'aaa' 'a*?a' '') <(<<'EOF'
input: `aaa'
(offset=0, size=1)
EOF
)

assert diff <(redump -m 'aaab' 'a*?ab' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
EOF
)

assert diff <(redump -m 'aaab' '(a+?)+?b' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
(offset=2, size=1)
EOF
)

assert diff <(redump -m '' 'a*?' '') <(<<'EOF'
input: `'
(offset=0, size=0)
EOF
)

assert diff <(redump -m '' 'a+?' '') <(<<'EOF'
input: `'
failed
EOF
)

assert diff <(redump -m 'aaa' '^a*?$' '') <(<<'EOF'
input: `aaa'
(offset=0, size=3)
EOF
)

assert diff <(redump -m 'aaab' '^a*?b' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
EOF
)

assert diff <(redump -m 'aaa bbb' '\ba+?\b' '') <(<<'EOF'
input: `aaa bbb'
(offset=0, size=3)
EOF
)

assert diff <(redump -m '12345' '[0-9]+?' '') <(<<'EOF'
input: `12345'
(offset=0, size=1)
EOF
)

assert diff <(redump -m 'bbbba' '[^a]+?a' '') <(<<'EOF'
input: `bbbba'
(offset=0, size=5)
EOF
)

assert diff <(redump -m 'abc123' '\w+?\d' '') <(<<'EOF'
input: `abc123'
(offset=0, size=4)
EOF
)

assert diff <(redump -m 'aaabbb' '(a+?)(b+)' '') <(<<'EOF'
input: `aaabbb'
(offset=0, size=6)
(offset=0, size=3)
(offset=3, size=3)
EOF
)

assert diff <(redump -m 'aaab' '(a*?)(a*)(b)' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
(offset=0, size=0)
(offset=0, size=3)
(offset=3, size=1)
EOF
)

assert diff <(redump -m 'aaac' '(a+?|b+?)c' '') <(<<'EOF'
input: `aaac'
(offset=0, size=4)
(offset=0, size=3)
EOF
)

assert diff <(redump -m 'bbbc' '(a+?|b+?)c' '') <(<<'EOF'
input: `bbbc'
(offset=0, size=4)
(offset=0, size=3)
EOF
)

assert diff <(redump -m 'a' 'a+?|aaa' '') <(<<'EOF'
input: `a'
(offset=0, size=1)
EOF
)