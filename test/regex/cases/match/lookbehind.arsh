
source $SCRIPT_DIR/../syntax/test_helper.arsh

# (?<=([ab]+)([bc]+))$
assert diff <(redump -m 'abc' '(?<=([ab]+)([bc]+))$' '') <(<<'EOF'
input: `abc'
(offset=3, size=0)
(offset=0, size=1)
(offset=1, size=2)
EOF
)

# (?<=\$)\d+(?:\.\d*)?
assert diff <(redump -m '$10.53' '(?<=\$)\d+(?:\.\d*)?' '') <(<<'EOF'
input: `$10.53'
(offset=1, size=5)
EOF
)

assert diff <(redump -m '10.53' '(?<=\$)\d+(?:\.\d*)?' '') <(<<'EOF'
input: `10.53'
failed
EOF
)

# (?<=(a)(b))c
assert diff <(redump -m 'abc' '(?<=(a)(b))c' '') <(<<'EOF'
input: `abc'
(offset=2, size=1)
(offset=0, size=1)
(offset=1, size=1)
EOF
)

# (?<=([ab])+)c
assert diff <(redump -m 'abc' '(?<=([ab])+)c' '') <(<<'EOF'
input: `abc'
(offset=2, size=1)
(offset=0, size=1)
EOF
)