
source $SCRIPT_DIR/../syntax/test_helper.arsh

# []
assert diff <(redump -m '' '[]' '') <(<<'EOF'
input: `'
failed
EOF
)

assert diff <(redump -m 'abc' '[]' '') <(<<'EOF'
input: `abc'
failed
EOF
)

# [^]
assert diff <(redump -m '' '[^]' '') <(<<'EOF'
input: `'
failed
EOF
)

assert diff <(redump -m 'a' '[^]' '') <(<<'EOF'
input: `a'
(offset=0, size=1)
EOF
)

assert diff <(redump -m 'гЃ‚' '[^]' '') <(<<'EOF'
input: `гЃ‚'
(offset=0, size=3)
EOF
)

assert diff <(redump -m $'\n' '[^]' '') <(<<EOF     # also match newline
input: \`${$'\n'}'
(offset=0, size=1)
EOF
)

assert diff <(redump -m $'\r' '[^]' '') <(<<EOF     # also match newline
input: \`${$'\r'}'
(offset=0, size=1)
EOF
)

# [a]
assert diff <(redump -m 'гЃ‚abc' '[a]' '') <(<<'EOF'
input: `гЃ‚abc'
(offset=3, size=1)
EOF
)

assert diff <(redump -m 'гЃ‚bc' '[a]' '') <(<<'EOF'
input: `гЃ‚bc'
failed
EOF
)

# [гЃ‚]
assert diff <(redump -m 'aгЃ‚bc' '[гЃ‚]' '') <(<<'EOF'
input: `aгЃ‚bc'
(offset=1, size=3)
EOF
)

assert diff <(redump -m 'гЃ„bc' '[гЃ‚]' '') <(<<'EOF'
input: `гЃ„bc'
failed
EOF
)

# [abc]
assert diff <(redump -m 'гЃ‚abc' '[abc]' '') <(<<'EOF'
input: `гЃ‚abc'
(offset=3, size=1)
EOF
)

assert diff <(redump -m 'гЃ‚bca' '[abc]' '') <(<<'EOF'
input: `гЃ‚bca'
(offset=3, size=1)
EOF
)

assert diff <(redump -m 'гЃ‚cab' '[abc]' '') <(<<'EOF'
input: `гЃ‚cab'
(offset=3, size=1)
EOF
)

assert diff <(redump -m 'гЃ‚гЃ„' '[abc]' '') <(<<'EOF'
input: `гЃ‚гЃ„'
failed
EOF
)


# [гЃ‚гЃ„@]
assert diff <(redump -m 'гЃ‚ab@cгЃ„' '[гЃ‚гЃ„@]' '') <(<<'EOF'
input: `гЃ‚ab@cгЃ„'
(offset=0, size=3)
EOF
)

assert diff <(redump -m 'ab@cгЃ„гЃ‚' '[гЃ‚гЃ„@]' '') <(<<'EOF'
input: `ab@cгЃ„гЃ‚'
(offset=2, size=1)
EOF
)

assert diff <(redump -m 'abcгЃ„гЃ‚@' '[гЃ‚гЃ„@]' '') <(<<'EOF'
input: `abcгЃ„гЃ‚@'
(offset=3, size=3)
EOF
)

assert diff <(redump -m 'abcгЃ†' '[гЃ‚гЃ„@]' '') <(<<'EOF'
input: `abcгЃ†'
failed
EOF
)

# [.*?]
assert diff <(redump -m 'ab.' '[.*?]' '') <(<<'EOF'
input: `ab.'
(offset=2, size=1)
EOF
)

assert diff <(redump -m 'a?b.' '[.*?]' '') <(<<'EOF'
input: `a?b.'
(offset=1, size=1)
EOF
)

# [^abc]
assert diff <(redump -m 'гЃ‚abc' '[^abc]' '') <(<<'EOF'
input: `гЃ‚abc'
(offset=0, size=3)
EOF
)

assert diff <(redump -m 'abc' '[^abc]' '') <(<<'EOF'
input: `abc'
failed
EOF
)

assert diff <(redump -m 'гЃ‚abc' '[^abc]' 'v') <(<<'EOF'
input: `гЃ‚abc'
(offset=0, size=3)
EOF
)

assert diff <(redump -m 'abc' '[^abc]' 'v') <(<<'EOF'
input: `abc'
failed
EOF
)

# [^гЃ‚гЃ„@]
assert diff <(redump -m 'гЃ‚ab@cгЃ„' '[^гЃ‚гЃ„@]' '') <(<<'EOF'
input: `гЃ‚ab@cгЃ„'
(offset=3, size=1)
EOF
)

assert diff <(redump -m '@гЃ„гЃ‚' '[^гЃ‚гЃ„@]' '') <(<<'EOF'
input: `@гЃ„гЃ‚'
failed
EOF
)

assert diff <(redump -m 'гЃ‚ab@cгЃ„' '[^гЃ‚гЃ„@]' 'v') <(<<'EOF'
input: `гЃ‚ab@cгЃ„'
(offset=3, size=1)
EOF
)

assert diff <(redump -m '@гЃ„гЃ‚' '[^гЃ‚гЃ„@]' 'v') <(<<'EOF'
input: `@гЃ„гЃ‚'
failed
EOF
)

# [A-Z0-9]
assert diff <(redump -m 'гЃ‚ab@CгЃ„' '[A-Z0-9]' '') <(<<'EOF'
input: `гЃ‚ab@CгЃ„'
(offset=6, size=1)
EOF
)

assert diff <(redump -m 'гЃ‚ab2@CгЃ„' '[A-Z0-9]' '') <(<<'EOF'
input: `гЃ‚ab2@CгЃ„'
(offset=5, size=1)
EOF
)

assert diff <(redump -m 'гЃ‚av@гЃ„' '[A-Z0-9]' '') <(<<'EOF'
input: `гЃ‚av@гЃ„'
failed
EOF
)

# [^A-Z0-9]
assert diff <(redump -m 'гЃ‚ab@CгЃ„' '[^A-Z0-9]' '') <(<<'EOF'
input: `гЃ‚ab@CгЃ„'
(offset=0, size=3)
EOF
)

assert diff <(redump -m 'AVC08' '[^A-Z0-9]' '') <(<<'EOF'
input: `AVC08'
failed
EOF
)

# [гЃ‚-гЃЉ]
assert diff <(redump -m 'ab@CгЃ„' '[гЃ‚-гЃЉ]' '') <(<<'EOF'
input: `ab@CгЃ„'
(offset=4, size=3)
EOF
)

assert diff <(redump -m 'ab@Cг‚“' '[гЃ‚-гЃЉ]' '') <(<<'EOF'
input: `ab@Cг‚“'
failed
EOF
)

# [^гЃ‚-гЃЉ]
assert diff <(redump -m 'ab@CгЃ„' '[^гЃ‚-гЃЉ]' '') <(<<'EOF'
input: `ab@CгЃ„'
(offset=0, size=1)
EOF
)

assert diff <(redump -m 'гЃ„гЃЉ' '[^гЃ‚-гЃЉ]' '') <(<<'EOF'
input: `гЃ„гЃЉ'
failed
EOF
)