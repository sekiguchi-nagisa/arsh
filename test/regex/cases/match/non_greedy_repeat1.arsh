
source $SCRIPT_DIR/../syntax/test_helper.arsh

# for non-greedy quantifier

# a*?
assert diff <(redump -m 'aaa' 'a*?' '') <(<<'EOF'
input: `aaa'
(offset=0, size=0)
EOF
)

# a*?a
assert diff <(redump -m 'aaa' 'a*?a' '') <(<<'EOF'
input: `aaa'
(offset=0, size=1)
EOF
)

# a*?ab
assert diff <(redump -m 'aaab' 'a*?ab' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
EOF
)

# a*?b
assert diff <(redump -m 'aaab' 'a*?b' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
EOF
)

# (a+?)+?b
assert diff <(redump -m 'aaab' '(a+?)+?b' '') <(<<'EOF'
input: `aaab'
(offset=0, size=4)
(offset=2, size=1)
EOF
)

# ^a*?$
assert diff <(redump -m 'aaa' '^a*?$' '') <(<<'EOF'
input: `aaa'
(offset=0, size=3)
EOF
)

# a*?$
assert diff <(redump -m 'aaa' 'a*?$' '') <(<<'EOF'
input: `aaa'
(offset=0, size=3)
EOF
)

# a[a-z]{2,4}?
assert diff <(redump -m 'abcdefghi' 'a[a-z]{2,4}?' '') <(<<'EOF'
input: `abcdefghi'
(offset=0, size=3)
EOF
)

# (a?b??)*
assert diff <(redump -m 'ab' '(a?b??)*' '') <(<<'EOF'
input: `ab'
(offset=0, size=2)
(offset=1, size=1)
EOF
)

# \w+?
assert diff <(redump -m 'abc' '\w+?' '') <(<<'EOF'
input: `abc'
(offset=0, size=1)
EOF
)

# \w*?
assert diff <(redump -m 'abc' '\w*?' '') <(<<'EOF'
input: `abc'
(offset=0, size=0)
EOF
)

# \w??
assert diff <(redump -m 'abc' '\w??' '') <(<<'EOF'
input: `abc'
(offset=0, size=0)
EOF
)

# \w{3}?
assert diff <(redump -m ' abcd' '\w{3}?' '') <(<<'EOF'
input: ` abcd'
(offset=1, size=3)
EOF
)

# a{0}?
assert diff <(redump -m '2025-12-31' 'a{0}?' 'u') <(<<'EOF'
input: `2025-12-31'
(offset=0, size=0)
EOF
)

# a{1}?
assert diff <(redump -m 'abc' 'b{1}?' 'u') <(<<'EOF'
input: `abc'
(offset=1, size=1)
EOF
)

# \w{3,4}?
assert diff <(redump -m ' abcd' '\w{3,4}?' '') <(<<'EOF'
input: ` abcd'
(offset=1, size=3)
EOF
)

# \w{2,}\w
assert diff <(redump -m 'abcdefgh' '\w{2,}\w' '') <(<<'EOF'
input: `abcdefgh'
(offset=0, size=8)
EOF
)

# \w{2,}?\w
assert diff <(redump -m 'abcdefgh' '\w{2,}?\w' '') <(<<'EOF'
input: `abcdefgh'
(offset=0, size=3)
EOF
)

# <.+>
assert diff <(redump -m '<p>hello</p>' '<.+>' '') <(<<'EOF'
input: `<p>hello</p>'
(offset=0, size=12)
EOF
)

# <.+?>
assert diff <(redump -m '<p>hello</p>' '<.+?>' '') <(<<'EOF'
input: `<p>hello</p>'
(offset=0, size=3)
EOF
)

# \w*?\s*
assert diff <(redump -m ' this is a' '\w*?\s*' '') <(<<'EOF'
input: ` this is a'
(offset=0, size=1)
EOF
)

# \w+?\s+
assert diff <(redump -m ' this is a' '\w+?\s+' '') <(<<'EOF'
input: ` this is a'
(offset=1, size=5)
EOF
)

# ^.*?(\d+)
assert diff <(redump -m 'apple123' '^.*?(\d+)' '') <(<<'EOF'
input: `apple123'
(offset=0, size=8)
(offset=5, size=3)
EOF
)

# (a+?)\1
assert diff <(redump -m 'aaaaaaa' '(a+?)\1' '') <(<<'EOF'
input: `aaaaaaa'
(offset=0, size=2)
(offset=0, size=1)
EOF
)

# ^(.+?)\d+?$
assert diff <(redump -m 'abc123' '^(.+?)\d+?$' '') <(<<'EOF'
input: `abc123'
(offset=0, size=6)
(offset=0, size=3)
EOF
)

# ^(.+?)\w+?$
assert diff <(redump -m 'abc123' '^(.+?)\w+?$' '') <(<<'EOF'
input: `abc123'
(offset=0, size=6)
(offset=0, size=1)
EOF
)

