
source $SCRIPT_DIR/../syntax/test_helper.arsh

# 1
assert diff <(redump -m '122' '1' '') <(<<'EOF'
input: `122'
(offset=0, size=1)
EOF
)

# √Ņ
assert diff <(redump -m '√Ņ2' '√Ņ' '') <(<<'EOF'
input: `√Ņ2'
(offset=0, size=2)
EOF
)

# „Āā
assert diff <(redump -m '„Āā„ĀĄ' '„Āā' '') <(<<'EOF'
input: `„Āā„ĀĄ'
(offset=0, size=3)
EOF
)

# ū§Öē
assert diff <(redump -m 'ū§Öē„ĀĄ' 'ū§Öē' '') <(<<'EOF'
input: `ū§Öē„ĀĄ'
(offset=0, size=4)
EOF
)

# \n
assert diff <(redump -m $'\n' '\n' '') <(<<EOF
input: \`${$'\n'}'
(offset=0, size=1)
EOF
)

# \r
assert diff <(redump -m $'\r' '\r' '') <(<<EOF
input: \`${$'\r'}'
(offset=0, size=1)
EOF
)

# \f
assert diff <(redump -m $'\f' '\f' '') <(<<EOF
input: \`${$'\f'}'
(offset=0, size=1)
EOF
)

# \t
assert diff <(redump -m $'\t' '\t' '') <(<<EOF
input: \`${$'\t'}'
(offset=0, size=1)
EOF
)

# \v
assert diff <(redump -m $'\v' '\v' '') <(<<EOF
input: \`${$'\v'}'
(offset=0, size=1)
EOF
)

# \xFF
assert diff <(redump -m '√Ņ2' '\xFF' '') <(<<'EOF'
input: `√Ņ2'
(offset=0, size=2)
EOF
)

# \cj
assert diff <(redump -m $'\x0A' '\cj' '') <(<<EOF
input: \`${$'\x0A'}'
(offset=0, size=1)
EOF
)

# \cJ
assert diff <(redump -m $'\x0A' '\cJ' '') <(<<EOF
input: \`${$'\x0A'}'
(offset=0, size=1)
EOF
)

# \c@   
assert diff <(redump -m '\c@' '\c@' '') <(<<'EOF'   # invalid escape
input: `\c@'
(offset=0, size=3)
EOF
)

# unanchored
assert diff <(redump -m '123ab„Āā„ĀĄ' '„Āā' '') <(<<'EOF'
input: `123ab„Āā„ĀĄ'
(offset=5, size=3)
EOF
)

assert diff <(redump -m '123ab„Āā„ĀĄ' '\u3042' '') <(<<'EOF'
input: `123ab„Āā„ĀĄ'
(offset=5, size=3)
EOF
)

assert diff <(redump -m '123ab„Āāū§Öē„ĀĄ' '\u{24155}' 'u') <(<<'EOF'
input: `123ab„Āāū§Öē„ĀĄ'
(offset=8, size=4)
EOF
)

assert diff <(redump -m '123ab„Āāū§Öē„ĀĄ' '\uD850\uDD55' '') <(<<'EOF'
input: `123ab„Āāū§Öē„ĀĄ'
(offset=8, size=4)
EOF
)

assert diff <(redump -m '123ab„Āāū§Öē„ĀĄ' '\uD850\uDD55' 'u') <(<<'EOF'
input: `123ab„Āāū§Öē„ĀĄ'
(offset=8, size=4)
EOF
)