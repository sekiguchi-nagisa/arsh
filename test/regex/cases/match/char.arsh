
source $SCRIPT_DIR/../syntax/test_helper.arsh

# 1
assert diff <(redump -m '122' '1' '') <(<<'EOF'
input: `122'
(offset=0, size=1)
EOF
)

# أ؟
assert diff <(redump -m 'أ؟2' 'أ؟' '') <(<<'EOF'
input: `أ؟2'
(offset=0, size=2)
EOF
)

# مپ‚
assert diff <(redump -m 'مپ‚مپ„' 'مپ‚' '') <(<<'EOF'
input: `مپ‚مپ„'
(offset=0, size=3)
EOF
)

# ً¤…•
assert diff <(redump -m 'ً¤…•مپ„' 'ً¤…•' '') <(<<'EOF'
input: `ً¤…•مپ„'
(offset=0, size=4)
EOF
)

# \n
assert diff <(redump -m $'\n' '\n' '') <(<<EOF
input: \`${$'\n'}'
(offset=0, size=1)
EOF
)

# \r
assert diff <(redump -m $'\r' '\r' '') <(<<EOF
input: \`${$'\r'}'
(offset=0, size=1)
EOF
)

# \f
assert diff <(redump -m $'\f' '\f' '') <(<<EOF
input: \`${$'\f'}'
(offset=0, size=1)
EOF
)

# \t
assert diff <(redump -m $'\t' '\t' '') <(<<EOF
input: \`${$'\t'}'
(offset=0, size=1)
EOF
)

# \v
assert diff <(redump -m $'\v' '\v' '') <(<<EOF
input: \`${$'\v'}'
(offset=0, size=1)
EOF
)

# \xFF
assert diff <(redump -m 'أ؟2' '\xFF' '') <(<<'EOF'
input: `أ؟2'
(offset=0, size=2)
EOF
)

# \cj
assert diff <(redump -m $'\x0A' '\cj' '') <(<<EOF
input: \`${$'\x0A'}'
(offset=0, size=1)
EOF
)

# \cJ
assert diff <(redump -m $'\x0A' '\cJ' '') <(<<EOF
input: \`${$'\x0A'}'
(offset=0, size=1)
EOF
)

# \c@   
assert diff <(redump -m '\c@' '\c@' '') <(<<'EOF'   # invalid escape
input: `\c@'
(offset=0, size=3)
EOF
)

# \u3042
assert diff <(redump -m  '@مپ‚' '\u3042' '') <(<<'EOF'
input: `@مپ‚'
(offset=1, size=3)
EOF
)

# \u{24155}
assert diff <(redump -m '@مپ‚ً¤…•' '\u{24155}' 'u') <(<<'EOF'
input: `@مپ‚ً¤…•'
(offset=4, size=4)
EOF
)

# \uDE86
assert diff <(redump -m $'#\xED\xBA\x86' '\uDE86' '') <(<<EOF # surrogate
input: \`${$'#\xED\xBA\x86'}'
(offset=1, size=3)
EOF
)

# \u{00d888}
assert diff <(redump -m $'#\xED\xA2\x88' '\u{00d888}' 'v') <(<<EOF # surrogate
input: \`${$'#\xED\xA2\x88'}'
(offset=1, size=3)
EOF
)

# unanchored
assert diff <(redump -m '123abمپ‚مپ„' 'مپ‚' '') <(<<'EOF'
input: `123abمپ‚مپ„'
(offset=5, size=3)
EOF
)

assert diff <(redump -m '123abمپ‚مپ„' '\u3042' '') <(<<'EOF'
input: `123abمپ‚مپ„'
(offset=5, size=3)
EOF
)

assert diff <(redump -m '123abمپ‚ً¤…•مپ„' '\u{24155}' 'u') <(<<'EOF'
input: `123abمپ‚ً¤…•مپ„'
(offset=8, size=4)
EOF
)

assert diff <(redump -m '123abمپ‚ً¤…•مپ„' '\uD850\uDD55' '') <(<<'EOF'
input: `123abمپ‚ً¤…•مپ„'
(offset=8, size=4)
EOF
)

assert diff <(redump -m '123abمپ‚ً¤…•مپ„' '\uD850\uDD55' 'u') <(<<'EOF'
input: `123abمپ‚ً¤…•مپ„'
(offset=8, size=4)
EOF
)

assert diff <(redump -m '()مپ‚مپ„@!مپ‚مپ„مپ†مپˆ#مپ‚مپ„مپ†مپˆمپٹ' 'مپ‚مپ„.\p{L}\p{L}' 'u') <(<<'EOF'
input: `()مپ‚مپ„@!مپ‚مپ„مپ†مپˆ#مپ‚مپ„مپ†مپˆمپٹ'
(offset=23, size=15)
EOF
)

assert diff <(redump -m '()مپ‚مپ„@!مپ‚مپ„مپ†مپˆ#مپ‚مپ„مپ†مپˆمپٹ' 'مپ‚مپ‘.\p{L}\p{L}' 'u') <(<<'EOF'
input: `()مپ‚مپ„@!مپ‚مپ„مپ†مپˆ#مپ‚مپ„مپ†مپˆمپٹ'
failed
EOF
)

assert diff <(redump -m '@())مپ„@!مپ‚مپ„مپ†مپˆ@مپ‚مپ„مپ†مپˆمپٹ' '~\p{L}+' 'u') <(<<'EOF'
input: `@())مپ„@!مپ‚مپ„مپ†مپˆ@مپ‚مپ„مپ†مپˆمپٹ'
failed
EOF
)