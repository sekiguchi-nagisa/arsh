assert diff <(redump -m '🇫🇷' '(?<=[\q{🇺🇸|🇨🇳|🇷🇺|🇬🇧|🇫🇷}&&\p{RGI_Emoji_Flag_Sequence}])' 'v') <(<<'EOF'
input: `🇫🇷'
(offset=8, size=0)
EOF
)

