@('[^\p{QMark}\P{Ideographic}\p{Bidi_M}]' 'vi' '@fold(U+00..U+10FFFF) - (@fold(prop:Quotation_Mark) + (@fold(U+00..U+10FFFF) - @fold(prop:Ideographic)) + @fold(dbp:Bidi_Mirrored))'),

@('[\q{A|B|C|!}]' 'v' '(U+41 + U+42 + U+43 + U+21)'),
@('[^\q{A|B|C|!}]' 'v' '!(U+41 + U+42 + U+43 + U+21)'),

@('[\q{A|B|C|!}あ&\q{い|う}]' 'v' '(U+41 + U+42 + U+43 + U+21 + U+3042 + U+26 + U+3044 + U+3046)'),
@('[^\q{A|B|C|!}あ&\q{い|う}]' 'v' '!(U+41 + U+42 + U+43 + U+21 + U+3042 + U+26 + U+3044 + U+3046)'),

@('[\q{A|B|C|!}[あ&\q{い|う}]]' 'v' '(U+41 + U+42 + U+43 + U+21 + (U+3042 + U+26 + U+3044 + U+3046))'),
@('[^\q{A|B|C|!}[^あ&\q{い|う}]]' 'v' '!(U+41 + U+42 + U+43 + U+21 + !(U+3042 + U+26 + U+3044 + U+3046))'),
@('(?<=[\q{A|B|C|!}[あ&\q{い|う}]])' 'v' '(U+41 + U+42 + U+43 + U+21 + (U+3042 + U+26 + U+3044 + U+3046))'),
@('(?<=[^\q{A|B|C|!}[^あ&\q{い|う}]])' 'v' '!(U+41 + U+42 + U+43 + U+21 + !(U+3042 + U+26 + U+3044 + U+3046))'),

@('[\q{A|B|C|!}[あ&\q{い|う}]]' 'vi' '@fold(U+41 + U+42 + U+43 + U+21 + (U+3042 + U+26 + U+3044 + U+3046))'),
@('[^\q{A|B|C|!}[^あ&\q{い|う}]]' 'iv' '@fold(U+00..U+10FFFF) - (@fold(U+41 + U+42 + U+43 + U+21) + (@fold(U+0..U+10FFFF) - @fold(U+3042 + U+26 + U+3044 + U+3046)))'),
@('(?<=[\q{A|B|C|!}[あ&\q{い|う}]])' 'vi' '@fold(U+41 + U+42 + U+43 + U+21 + (U+3042 + U+26 + U+3044 + U+3046))'),
@('(?<=[^\q{A|B|C|!}[^あ&\q{い|う}]])' 'iv' '@fold(U+00..U+10FFFF) - (@fold(U+41 + U+42 + U+43 + U+21) + (@fold(U+0..U+10FFFF) - @fold(U+3042 + U+26 + U+3044 + U+3046)))'),

# &&
@('[\w&&\d]' 'v' '(U+30..U+39)'),
@('[\w&&\d]' 'vi' '(U+30..U+39)'),
@('[^\w&&\d]' 'v' '!(U+30..U+39)'),
@('[^\w&&\d]' 'vi' '@fold(U+00..U+10FFFF) - (U+30..U+39)'),
@('(?<=[^\w&&\d])' 'v' '!(U+30..U+39)'),
@('(?<=[^\w&&\d])' 'vi' '@fold(U+00..U+10FFFF) - (U+30..U+39)'),
@('[\w&&\d&&[1-8]]' 'v' '(U+31..U+38)'),
@('[^\w&&\d&&[1-8]]' 'v' '!(U+31..U+38)'),
@('[\w&&\d&&[^1-8]]' 'v' '(U+30 + U+39)'),

# --
@('[\w--\d]' 'v' '(U+41..U+5A + U+5F + U+61..U+7A)'),
@('[\w--\d]' 'vi' '@fold(U+41..U+5A + U+5F + U+61..U+7A)'),
@('[^\w--\d]' 'v' '!(U+41..U+5A + U+5F + U+61..U+7A)'),
@('[^\w--\d]' 'vi' '@fold(U+00..U+10FFFF) - @fold(U+41..U+5A + U+5F + U+61..U+7A)'),
@('(?<=[^\w--\d])' 'v' '!(U+41..U+5A + U+5F + U+61..U+7A)'),
@('(?<=[^\w--\d])' 'vi' '@fold(U+00..U+10FFFF) - @fold(U+41..U+5A + U+5F + U+61..U+7A)'),
@('[\w--\d--_--[a-z]]' 'v' '(U+41..U+5A)'),
@('[^\w--\d--_--[a-z]]' 'v' '!(U+41..U+5A)'),
@('[\w--\d--_--[^a-z]]' 'v' '(U+61..U+7A)'),
])

_main(param : _Param) {
    {
        auto_gen_header

        ## generate table
        for def in $defs {
            $def.emitTable()
        }

        ## generate case
        echo
        echo "static constexpr CharSetMatcherEntry charSetMatcherCases[] = {"
        for def in $defs {
            $def.emitCase()
        }
        echo "};"
    } with > ${param.output}
}

shctl is-sourced || _main $@