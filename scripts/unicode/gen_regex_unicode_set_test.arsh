#!/usr/bin/env arsh

source $SCRIPT_DIR/guniset_helper.arsh
source $SCRIPT_DIR/gen_lone_property_table.arsh as _lone_table

[<CLI(toplevel:$true)>]
type _Param() {
    [<Arg(required:$true, help: "specify output file")>]
    var output = ""
}

function codesToLiteral(codes: [Int]): String {
    assert (printf -v var '\U%04X' $codes) : "$codes"
    return "\$'" + $reply['var'] + "'"
}

function codesToUTF8(codes: [Int]): String? {
    var literal = $codesToLiteral($codes)
    return try { $MODULE._func($literal)()! as String as String?; } catch e { $none; }
}

function escapeUTF8(str: String): String {
    assert $str.validate()
    return $codesToLiteral($str.codes())
}

let _rand8 = {
    var ss: [Int]
    for(var i = 0; $i < 256; $i++) {
        $ss.add($i)
    }
    function() => {
        $ss.shuffle(42)
        $ss[0]
    }
}

function genCode(): Int {
    var code = 0
    while($true) {
        $code = $_rand8() << 16 or $_rand8() << 8 or $_rand8()
        $code = $code and ((1 << 21) - 1)
        if $code <=0x10FFFF && ($code < 0xD800 || $code > 0xDFFF){
            break
        }
    }
    return $code
}

function mutateCodes(codes: [Int]) {
    for(var i = 0; $i < $codes.size(); $i++) {
        $codes[$i] = $genCode()
    }
}

type StrSet {
    let _map: [String: Bool]   # (utf8, _)
}

function sample(limit: Int): [(String, String)] for StrSet {
    var ret: [(String, String)]
    for k,_ in $this._map {
        $ret.add(($escapeUTF8($k), $k))
    }
    return $ret.shuffle(42).slice(0, $limit < 0 ? 0 : $limit)
}

function sampleNoExists(limit: Int): [(String, String)] for StrSet {
    var ret = $this.sample($limit)
    for(var i = 0; $i < $ret.size(); $i++) {
        var e = $ret[$i]
        var n = $e._1
        var codes = $n.codes()
        do {
            $mutateCodes($codes)
            $n = $codesToUTF8($codes) ?? continue
        } while $this._map.get($n)
        $ret[$i] = ($escapeUTF8($n), $n)
    }
    return $ret
}

let _emojiSeqCache: [String: StrSet]

type SetGen {
    let type: String
    let ops: [String]
}

function toSet(): StrSet for SetGen {
    return case $this.type {
        'codepoint' => {
            var map: [String:Bool]
            for e in <(guniset sample --ratio 10 --format=string -- ${$this.ops[0]}) {
                $map.put($e, $true)
            }
            new StrSet($map)
        }
        'list' => {
            var map: [String: Bool]
            for e in $this.ops {
                $map.put($e, $true)
            }
            new StrSet($map)
        }
        'emoji' => $_emojiSeqCache[$this.ops[0]]
        else => throw new Error("unsupported: ${this.type}")
    }
}

function sampleCodePoints(limit: Int): ([(String, String)], [(String, String)]) for SetGen {
    assert $this.type == 'codepoint'
    var matches: [(String, String)]
    var noMatches: [(String, String)]
    for e in <(guniset sample --seed 42 --limit $limit -- ${$this.ops[0]}) {
        var codes = [$e.slice(2).toInt(16)!]
        $matches.add(($codesToLiteral($codes), $codesToUTF8($codes) ?? {echo 1>&2 "[warn] ignore: $e"; continue; }))
    }
    for e in <(guniset sample --seed 42 --limit $limit -- "!(${$this.ops[0]})") {
        var codes = [$e.slice(2).toInt(16)!]
        $noMatches.add(($codesToLiteral($codes), $codesToUTF8($codes) ?? {echo 1>&2 "[warn] ignore: $e"; continue; }))
    }
    return ($matches, $noMatches)
}

function set(setop: String): SetGen {
    return new SetGen('codepoint', [$setop])
}

function list(ss: [String]): SetGen {
    return new SetGen('list', $ss)
}

function emoji(prop: String): SetGen {
    if !$_emojiSeqCache.get($prop) {
        var map: [String: Bool]
        for e in <(guniset strings --format=string -- $prop) {
            $map.put($e, $true)
        }
        $_emojiSeqCache[$prop] = new StrSet($map)
    }
    return new SetGen('emoji', [$prop])
}

type TestCase {
    let pattern: Regex
    let matches: [(String,String)]
    let noMatches: [(String,String)]
}

function emit() for TestCase {
    echo '$assertRegex('
    printf "\t\$pattern: \$${this.pattern},\n"
    if $this.matches.empty() {
        printf "\t\$matches: new [String](),\n"
    } else {
        printf "\t\$matches: [\n"
        printf "\t\t%s,  # %s\n" ${this.matches}
        printf "\t],\n"
    }
    if $this.noMatches.empty() {
        printf "\t\$noMatches: new [String](),\n"
    } else {
        printf "\t\$noMatches: [\n"
        printf "\t\t%s,  # %s\n" ${this.noMatches}
        printf "\t],\n"
    }
    echo ")"
}

type TestScript() {
    let cases: [TestCase]
}

function emit() for TestScript {
    echo "#\$test(\$status = 0, \$out = \$'pass: ${$this.cases.size()}\n')"
    echo
    echo "# Auto-generated by scripts/unicode/$(basename $ARG0)"
    echo
    echo 'source $SCRIPT_DIR/regex_helper.arsh'
    echo
    for case in $this.cases {
        $case.emit()
    }
    echo 'echo pass: $REGEX_TEST_PASS_COUNT'
}

function def(p: Regex, ss: SetGen) for TestScript {
    case $ss.type {
        'codepoint' => {
            var ret = $ss.sampleCodePoints(10)
            $this.cases.add(new TestCase($p, $matches:$ret._0, $noMatches:$ret._1))
        }
        else => {
            var strSet = $ss.toSet()
            $this.cases.add(new TestCase($p, $matches:$strSet.sample(10), $noMatches:$strSet.sampleNoExists(10)))
        }
    }
}

type TestScripts() {
    let scripts: [String:TestScript]
}

function testScript(name: String, builder: (TestScript)-> Void) for TestScripts {
    var script = new TestScript()
    $builder($script)
    assert !$this.scripts.put($name, $script)
}

function getQuery(def : _lone_table.LoneProperty): String? {
    let query = if let q = $def.query {
        $q
    } elif let p = $def.prefix {
        "$p:${def.name}"
    } elif $def.name == 'Assigned' {
        "!(cat:Cn)"
    } else {
        $none
    }
    return $query
}


let _builder = function(tss: TestScripts) => {
    $tss.testScript('regex_unicode_property_gc.arsh', function(ts: TestScript)=>{
        for line in <(guniset enum gc) {
            for cat in $line.split(', ') {
                $ts.def(new Regex("^[\\p{$cat}]\$", 'u'), $set("gc:$cat"))
            }
        }
    })
    $tss.testScript('regex_unicode_property_sc.arsh', function(ts: TestScript)=>{
        for line in <(guniset enum sc) {
            for cat in $line.split(', ') {
                $ts.def(new Regex("^[\\p{Script=$cat}]\$", 'u'), $set("sc:$cat"))
            }
        }
    })
    $tss.testScript('regex_unicode_property_scx.arsh', function(ts: TestScript)=>{
        for line in <(guniset enum scx) {
            for cat in $line.split(', ') {
                $ts.def(new Regex("^[\\p{Script_Extensions=$cat}]\$", 'u'), $set("scx:$cat"))
            }
        }
    })
    $tss.testScript('regex_unicode_property_lone.arsh', function(ts) => {
        for def in $_lone_table.defs {
            let query = $getQuery($def) ?? { echo 1>&2 "[warn] ignore: ${def.name}"; continue; }
            var ss = [$def.name]
            if let abbr = $def.abbr {
                $ss.add($abbr)
            }
            for name in $ss {
                $ts.def(new Regex("^[\\p{${name}}]\$", 'u'), $set($query))
            }
        }
        var defs = $_lone_table.defs.copy().shuffle(42)
        for(var i = 0; $i < 10; $i+=2) {
            let query1 = $getQuery($defs[$i]) ?? { echo 1>&2 "[warn] ignore: ${$defs[$i].name}"; continue; }
            let query2 = $getQuery($defs[$i+1]) ?? { echo 1>&2 "[warn] ignore: ${$defs[$i+1].name}"; continue; }
            $ts.def(new Regex("^[\\p{${$defs[$i].name}}\\p{${$defs[$i+1].name}}]\$", 'u'), $set($query1 + " + " + $query2))
        }
    })
    $tss.testScript('regex_unicode_property_emoji.arsh', function(ts) =>{
        for name in ['Basic_Emoji', 'Emoji_Keycap_Sequence', 'RGI_Emoji_Flag_Sequence',
                'RGI_Emoji_Modifier_Sequence', 'RGI_Emoji_Tag_Sequence', 
                'RGI_Emoji_ZWJ_Sequence', 'RGI_Emoji'] {
            $ts.def(new Regex("^[\\p{${name}}]\$", 'v'), $emoji($name))
        }
        # $ts.def($/\p{}/v, $emoji($name))
    })
}


_main(param : _Param) {
    var scripts: TestScripts
    $_builder($scripts)
    for name, script in $scripts.scripts {
        $script.emit() with > ${param.output}/$name
    }
}

shctl is-sourced || _main $@